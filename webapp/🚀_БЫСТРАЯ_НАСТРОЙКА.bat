@echo off
chcp 65001 >nul
title Быстрая настройка автоматического деплоя
color 0A

echo.
echo ╔═══════════════════════════════════════════════════════╗
echo ║   🚀 БЫСТРАЯ НАСТРОЙКА АВТОМАТИЧЕСКОГО ДЕПЛОЯ         ║
echo ╚═══════════════════════════════════════════════════════╝
echo.
echo Это займёт 5-10 минут. Следуйте инструкциям!
echo.
pause

REM ШАГ 1: Настройка GitHub
echo.
echo ┌─────────────────────────────────────────────────────┐
echo │ ШАГ 1 из 3: Настройка GitHub                        │
echo └─────────────────────────────────────────────────────┘
echo.
cd /d "%~dp0\.."
call "webapp\БЫСТРАЯ_НАСТРОЙКА_GITHUB.bat"
if %errorlevel% neq 0 (
    echo.
    echo ❌ Ошибка настройки GitHub
    pause
    exit /b 1
)

REM ШАГ 2: Инструкция Netlify
echo.
echo ┌─────────────────────────────────────────────────────┐
echo │ ШАГ 2 из 3: Подключение Netlify к GitHub             │
echo └─────────────────────────────────────────────────────┘
echo.
echo Откройте браузер и следуйте инструкциям:
echo.
echo 1. Зайдите на: https://app.netlify.com/
echo 2. Add new site → Import from GitHub
echo 3. Выберите ваш репозиторий
echo 4. Настройки:
echo    Base directory:    webapp
echo    Publish directory: .
echo 5. Deploy site
echo.
echo Открыть Netlify в браузере?
set /p open="(y/n): "
if /i "%open%"=="y" (
    start https://app.netlify.com/
)
echo.
echo Нажмите любую клавишу, когда закончите настройку Netlify...
pause

REM ШАГ 3: Запуск автоматического деплоя
echo.
echo ┌─────────────────────────────────────────────────────┐
echo │ ШАГ 3 из 3: Запуск автоматического деплоя           │
echo └─────────────────────────────────────────────────────┘
echo.
cd /d "%~dp0"

echo Выберите вариант запуска:
echo.
echo   1. Запуск вручную (каждый раз при включении ПК)
echo   2. Автозапуск (запускается сам) - РЕКОМЕНДУЕТСЯ
echo.
set /p autostart="Ваш выбор (1-2): "

if "%autostart%"=="1" (
    echo.
    echo Запускаю автоматический деплой...
    start /B pythonw auto_deploy_background.py
    echo.
    echo ✅ Автоматический деплой запущен!
) else if "%autostart%"=="2" (
    echo.
    echo Настройка автозапуска...
    echo.
    echo 1. Нажмите Win + R
    echo 2. Введите: shell:startup
    echo 3. Скопируйте ярлык файла АВТОЗАПУСК_ПРИ_СТАРТЕ.bat
    echo    в открывшуюся папку
    echo.
    echo Открыть папку автозагрузки?
    set /p open="(y/n): "
    if /i "%open%"=="y" (
        start shell:startup
    )
    echo.
    echo ✅ Автозапуск настроен!
)

echo.
echo ╔═══════════════════════════════════════════════════════╗
echo ║   ✅ НАСТРОЙКА ЗАВЕРШЕНА!                             ║
echo ╚═══════════════════════════════════════════════════════╝
echo.
echo Теперь:
echo • Редактируйте файлы (или просите меня редактировать)
echo • Сохраняйте изменения
echo • ВСЁ ОСТАЛЬНОЕ АВТОМАТИЧЕСКИ!
echo.
echo Изменения появятся в Telegram через 1-2 минуты
echo после сохранения файла.
echo.
pause

